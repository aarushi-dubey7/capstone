# ─────────────────────────────────────────────────────────────────────────────
# CONVEX  (required)
# ─────────────────────────────────────────────────────────────────────────────
# Get this by running: npx convex dev
# It will open a browser to create/login to your Convex project and then
# write the URL to .env.local automatically.
VITE_CONVEX_URL=https://your-project.convex.cloud


# ─────────────────────────────────────────────────────────────────────────────
# GROQ  (required — stored in Convex, NOT in this file)
# ─────────────────────────────────────────────────────────────────────────────
# 1. Sign up at https://console.groq.com
# 2. Create an API key under "API Keys"
# 3. Add it to Convex (NOT to .env) so it stays server-side:
#      npx convex env set GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
#
# The key is used by convex/groq.ts to call llama-3.2-90b-vision-preview
# for parsing student schedule images.
#
# GROQ_API_KEY is intentionally absent from this file — it must live in
# Convex environment variables only, never in the browser bundle.


# ─────────────────────────────────────────────────────────────────────────────
# HOW TO GET STARTED
# ─────────────────────────────────────────────────────────────────────────────
# 1. npm install
# 2. npx convex dev          ← creates convex/ _generated files + sets VITE_CONVEX_URL in .env.local
# 3. npx convex env set GROQ_API_KEY=gsk_...   ← paste your Groq key
# 4. npm run dev             ← starts the Vite dev server
#
# For production (GitHub Pages):
# 5. npm run build           ← outputs to dist/
# 6. npx convex deploy       ← deploys Convex functions
# 7. Push dist/ to your gh-pages branch
